# Red de Stellar para la wallet. TESTNET por default; PUBLIC para mainnet.
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Pinata (IPFS pinning provider) — JWT con permiso de la API v3 "Files: Write"
# (lo que usa pinata.upload.public.file). Los scopes legacy de pinning NO sirven.
# Server-side only, NUNCA exponer al cliente. Ver apps/web/docs/pinata-setup.md.
PINATA_JWT=

# Opcional: dedicated gateway de Pinata (ej: tu-subdominio.mypinata.cloud).
# Sin esto se usa el gateway público gateway.pinata.cloud. Solo para retrieval.
# PINATA_GATEWAY=
