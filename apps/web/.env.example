# Red de Stellar para la wallet. TESTNET por default; PUBLIC para mainnet.
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# IPFS via Storacha — server-side only, NUNCA exponer al cliente.
# Generar credencial siguiendo https://docs.storacha.network
# (ver pasos exactos en apps/web/docs/storacha-setup.md).
# STORACHA_KEY: clave privada del agente (empieza con "Mg...").
# STORACHA_PROOF: delegation UCAN en base64 que autoriza al agente sobre el space.
STORACHA_KEY=
STORACHA_PROOF=
